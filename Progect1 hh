   "id": "a016971e",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Смотрим, какие уникальные значения есть в столбце 'Занятость'\n",
    "print(\"Уникальные значения в столбце 'Занятость':\")\n",
    "print(df['Занятость'].unique()) # Выводим на экран\n",
    "\n",
    "# собираем все возможные типы занятости из данных\n",
    "lst1 = df['Занятость'].unique()  # первый список - уникальные записи из df - но они составные\n",
    "lst2 = []  # список будет хранить отдельные типы занятости после того, как мы разобьем составные строки\"\n",
    "\n",
    "for i in lst1:  # работаем с каждым составным объектом списка lst1 Цикл будет перебирать по очереди каждый элемент из списка lst1, проверять, является ли переменная i строкой. В данных могут быть пропуски (NaN - Not a Number), и с ними нельзя работать как со строками Если i - строка, то выполняем код внутри if\n",
    "    if isinstance(i, str):  # проверяем, что значение - строка (не NaN)\n",
    "        # разбиваем составной объект на конкретные \"Занятости\" и убираем лишние пробелы\n",
    "        items = [item.strip() for item in i.split(\",\")] # перебирает каждую полученную часть и удаляет лишние пробелы в начале и конце строки\n",
    "        lst2.extend(items) #добавляем элементы списка\n",
    "\n",
    "# Убираем дубликаты и получаем список уникальных типов занятости set(lst2) - превращает список lst2 во множество (set).Множество автоматически удаляет все повторяющиеся значения. list(...) - превращает множество обратно в список Т.о.employment_types - будет содержать каждый тип занятости только один раз\n",
    "\n",
    "employment_types = list(set(lst2))\n",
    "\n",
    "print(f\"n\\Найденные типы занятости: {employment_types}\")\n",
    "\n",
    "# Для каждого типа занятости создаем новый столбец-мигалку (булева маска). Создаём новый цикл, который перебирает каждый тип занятости. emp_type - переменная, которая на каждом шаге содержит очередной тип (например, \"полная занятость\")\n",
    "for emp_type in employment_types:\n",
    "    # Проверяем, есть ли текущий тип занятости в строке\n",
    "    # str.contains(emp_type, na=False) - ищем подстроку, если NaN то False\n",
    "    df[f'занятость_{emp_type}'] = df['Занятость'].str.contains(emp_type, na=False)\n",
    "\n",
    "# Смотрим уникальные значения в столбце 'График'\n",
    "print(\"n\\Уникальные значения в столбце 'График':\")\n",
    "print(df['График'].unique())\n",
    "\n",
    "# собираем все возможные типы графика из данных\n",
    "lst3 = df['График'].unique()  # уникальные записи из df - составные\n",
    "lst4 = []  # будет содержать конкретные типы графика\n",
    "\n",
    "for i in lst3:  # работаем с каждым составным объектом списка lst3\n",
    "    if isinstance(i, str):  # проверяем, что значение - строка (не NaN)\n",
    "        # разбиваем составной объект на конкретные типы графика и убираем лишние пробелы\n",
    "        items = [item.strip() for item in i.split(\",\")]\n",
    "        lst4.extend(items)\n",
    "\n",
    "# Убираем дубликаты и получаем список уникальных типов графика\n",
    "schedule_types = list(set(lst4))\n",
    "\n",
    "print(f\"\\nНайденные типы графика: {schedule_types}\")\n",
    "\n",
    "# Для каждого типа графика создаем новый столбец-мигалку\n",
    "for schedule_type in schedule_types:\n",
    "    df[f'график_{schedule_type}'] = df['График'].str.contains(schedule_type, na=False)\n",
    "\n",
    "#  создаем список с исходными столбцами\n",
    "columns = ['Занятость', 'График']\n",
    "\n",
    "# Добавляем колонки для каждого типа занятости\n",
    "for real_type in employment_types:\n",
    "    columns.append('занятость_' + real_type)\n",
    "\n",
    "# Добавляем колонки для каждого типа графика\n",
    "for real_type in schedule_types:\n",
    "    columns.append('график_' + real_type)\n",
    "\n",
    "print(\"n\\Результат преобразования (первые 5 строк):\")\n",
    "print(df[columns].head())\n",
    "\n",
    "\n"
   ]
