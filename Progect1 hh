    "def extract_experience_months(experience_text):\n",
    "\n",
    "    # Проверка пропусков\n",
    "    if pd.isna(experience_text) or experience_text == \"Не указано\":#Проверяем, является ли значение пропущенным или содержит текст \"Не указано\"\n",
    "        return float('NaN')\n",
    "\n",
    "    # Берём только первую часть\n",
    "    text = str(experience_text) #Превращаем любой тип данных в текст (строку)\n",
    "    first_line = text.split('\\n')[0]# Разбиваем текст на строки и берём самую первую\n",
    "    first_part = first_line.split('.')[0] # Отрезаем текст после первой точки\n",
    "\n",
    "    # Инициализируем переменные\n",
    "    years = 0\n",
    "    months = 0\n",
    "\n",
    "    # Поиск годов (простой перебор слов)\n",
    "    words = first_part.split()  # Разбиваем текст на слова\n",
    "\n",
    "    for i, word in enumerate(words):\n",
    "        # Если нашли число и следующее слово указывает на годы\n",
    "        if word.isdigit():  # Проверяем, является ли слово числом\n",
    "            if i + 1 < len(words):  # Проверяем, есть ли следующее слово\n",
    "                next_word = words[i + 1].lower()  # Следующее слово в нижнем регистре\n",
    "\n",
    "                # Проверяем, обозначает ли следующее слово годы\n",
    "                if next_word in ['год', 'года', 'лет', 'годы']:\n",
    "                    years = int(word)\n",
    "\n",
    "                # Проверяем, обозначает ли следующее слово месяцы\n",
    "                elif next_word in ['месяц', 'месяца', 'месяцев']:\n",
    "                    months = int(word)\n",
    "\n",
    "    # Если ничего не нашли\n",
    "    if years == 0 and months == 0:\n",
    "        return float('NaN')\n",
    "\n",
    "    return years * 12 + months\n",
    "    # Применяем функцию ко всем строкам столбца 'Опыт работы'\n",
    "df['Опыт работы (месяц)'] = df['Опыт работы'].apply(extract_experience_months)\n",
