    "}\n",
    "\n",
    "# создаём новые пустые столбцы\n",
    "df['ЗП_сумма'] = 0.0 # Создаём столбец для суммы зарплаты (пока все значения = 0)\n",
    "df['ЗП_валюта_ISO'] = '' # Создаём столбец для кода валюты (пока пустые строки)\n",
    "\n",
    "# проходим по каждой строке таблицы\n",
    "# len(df) - количество строк в таблице\n",
    "# range(len(df)) - создаём числа от 0 до (количество строк - 1)\n",
    "# i - номер текущей строки\n",
    "for i in range(len(df)):\n",
    "    our_text = str(df.loc[i, 'ЗП'])  # берём текст из столбца 'ЗП' в текущей строке,str() - превращает значение в строку\n",
    "\n",
    "    #ищем число (цифры) в тексте\n",
    "    # \\d+ - означает \"одна или несколько цифр\"\n",
    "    # findall - находит все цифры в тексте и возвращает их списком\n",
    "    numbers = re.findall(r'\\d+', our_text)\n",
    "    if len(numbers) > 0:# Если нашли хотя бы одно число\n",
    "        # берём первое число\n",
    "        df.loc[i, 'ЗП_сумма'] = float(numbers[0]) #превращает текст в число\n",
