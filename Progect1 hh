   },
   "outputs": [],
   "source": [
    "# Определим первоначальное количество строк\n",
    "print(f\"Исходное количество строк: {len(df)}\")\n",
    "\n",
    "# Находим полные дубликаты (строки, которые совпадают целиком по всем столбцам)\n",
