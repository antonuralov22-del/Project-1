   "source": [
    "# Создаём список городов-миллионников\n",
    "million_cities = ['Новосибирск', 'Екатеринбург', 'Нижний Новгород', 'Казань',\n",
    "                   'Челябинск', 'Омск', 'Самара', 'Ростов-на-Дону', 'Уфа',\n",
    "                   'Красноярск', 'Пермь', 'Воронеж', 'Волгоград']\n",
    "\n",
    "# Функция для определения города\n",
    "# ПРОВЕРКА НА ПУСТОЕ ЗНАЧЕНИЕ\n",
    "    # pd.isna(text) - проверяет, является ли значение пустым (NaN - Not a Number)\n",
    "    # Если значение пустое или это пустая строка (text == '')\n",
    "def extract_city(text):\n",
    "    if pd.isna(text) or text == '':\n",
    "        return 'другие'\n",
    "    # РАЗБИВАЕМ СТРОКУ НА ЧАСТИ\n",
    "    # text.split(',') - разбивает строку по запятым и создаёт список\n",
    "    # Разбиваем строку по запятой\n",
    "    parts = text.split(',')\n",
    "    # БЕРЁМ ПЕРВУЮ ЧАСТЬ (ЭТО ГОРОД)\n",
    "    # parts[0] - первый элемент списка\n",
    "    # .strip() - удаляет лишние пробелы в начале и конце строки\n",
    "    city = parts[0].strip()\n",
    "\n",
    "    # Проверяем категории\n",
    "    # Если город - Москва ИЛИ Санкт-Петербург\n",
    "    if city == 'Москва' or city == 'Санкт-Петербург':\n",
    "        return city  # Возвращаем название города\n",
    "    # Проверяем, входит ли город в список миллионников\n",
    "    # Оператор 'in' проверяет, есть ли значение в списке\n",
    "    elif city in million_cities:\n",
    "        return 'город-миллионник'\n",
    "    # Если ни одно условие не подошло\n",
    "    else:\n",
    "        return 'другие'\n",
    "\n",
    "# Функция для определения готовности к переезду - определяет, готов ли соискатель к переезду Возвращает True (готов) или False (не готов)\n",
    "# ПРОВЕРКА НА ПУСТОЕ ЗНАЧЕНИЕ\n",
    "    # Если данных нет, то считаем, что не готов к переезду\n",
    "def extract_relocation(text):\n",
    "    if pd.isna(text) or text == '':\n",
    "        return False\n",
    "    # Далее, приводим тест к нижнему регистру\n",
    "    # .lower() - преобразует все буквы в строчные (маленькие)\n",
    "    # Это нужно, чтобы не зависеть от регистра, так как 'Готов' и 'готов' будут одинаковыми\n",
    "    # Ищем ключевые слова, означающие готовность к переезду\n",
    "    text_lower = text.lower()\n",
    "\n",
    "    # Если есть \"готов к переезду\" или \"готова к переезду\" или \"хочу переехать\"\n",
    "    if ('готов к переезду' in text_lower or\n",
    "        'готова к переезду' in text_lower or\n",
    "        'хочу переехать' in text_lower):\n",
    "        return True\n",
    "    # Проверяем, если не готов к переезду. Если явно сказано \"не готов\" или \"не готова\"\n",
    "    elif ('не готов к переезду' in text_lower or\n",
    "          'не готова к переезду' in text_lower):\n",
    "        return False\n",
    "    # Если ничего не нашли (нет информации о переезде)\n",
    "    else:\n",
    "        return False\n",
    "\n",
    "# Функция для определения готовности к командировкам#\n",
    "def extract_business_trip(text):\n",
    "    if pd.isna(text) or text == '':\n",
    "        return False\n",
    "\n",
    "    text_lower = text.lower()\n",
    "\n",
    "    # Если есть слова, означающие готовность к командировкам Возвращает True (готов) или False (не готов)\n",
    "    if ('готов к командировкам' in text_lower or\n",
    "        'готова к командировкам' in text_lower or\n",
    "        'готова к редким командировкам' in text_lower or\n",
    "        'готов к редким командировкам' in text_lower):\n",
    "        return True\n",
    "    # Если явно сказано \"не готов\" или \"не готова\"\n",
    "    elif ('не готов к командировкам' in text_lower or\n",
    "          'не готова к командировкам' in text_lower):\n",
    "        return False\n",
    "    else:\n",
    "        # По умолчанию считаем, что не готов к командировкам\n",
    "        return False\n",
    "\n",
    "# Применяем функции к столбцу 'Город, переезд, командировки'\n",
    "df['Город'] = df['Город, переезд, командировки'].apply(extract_city)\n",
    "df['Готовность к переезду'] = df['Город, переезд, командировки'].apply(extract_relocation)\n",
    "df['Готовность к командировкам'] = df['Город, переезд, командировки'].apply(extract_business_trip)\n",
    "# Проверяем результат\n",
    "print(df[['Город', 'Готовность к переезду', 'Готовность к командировкам']].head(10))\n"
   ]
